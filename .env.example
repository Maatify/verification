# ============================================================
# Verification Module Configuration
# ============================================================

# Secret key used to hash verification codes using HMAC-SHA256.
#
# The OTP itself (e.g. 123456) is NEVER stored directly.
# Instead we store:
#
#   hash_hmac('sha256', code, VERIFICATION_SECRET)
#
# This protects against:
# - database leaks
# - rainbow table attacks
# - offline brute force attempts
#
# IMPORTANT:
# - REQUIRED in production
# - Must be a long random value (recommended: 32+ bytes)
# - Must be kept secret
# - Do NOT commit real production values to version control
#
# Generate a secure value with:
#   openssl rand -hex 32
#
# NOTE:
# Changing this value will invalidate ALL currently active
# verification codes.

VERIFICATION_SECRET=your_random_secret_here

# ------------------------------------------------------------
# Redis Configuration
# ------------------------------------------------------------

# Prefix used for Redis keys in the verification rate limiter.
# This helps avoid key collisions if multiple applications share
# the same Redis instance.
#
# Example generated key:
# maatify:verification:rate:user:154:login
#
# Optional — can be left as default.

VERIFICATION_REDIS_PREFIX=maatify:verification